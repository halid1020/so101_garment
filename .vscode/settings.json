{
  // LaTeX Workshop (install the "latex-workshop" extension): builds
  // documents/paper/teleoperation/main.tex with latexmk automatically on save.
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.latex.recipe.default": "latexmk",
  "latex-workshop.latex.tools": [
    {
      "name": "latexmk",
      "command": "latexmk",
      "args": [
        "-pdf",
        "-interaction=nonstopmode",
        "-synctex=1",
        "-file-line-error",
        "-outdir=%OUTDIR%",
        "%DOC%"
      ]
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "latexmk",
      "tools": ["latexmk"]
    }
  ],
  // Multi-file project: sections/*.tex are \input into main.tex — always
  // build the root document, never the fragment being edited.
  "latex-workshop.latex.rootFile.useSubFile": false,
  "latex-workshop.latex.search.rootFiles.include": [
    "documents/paper/**/main.tex"
  ],
  "latex-workshop.view.pdf.viewer": "tab",
  "latex-workshop.latex.autoClean.run": "onBuilt",
  "latex-workshop.latex.clean.fileTypes": [
    "*.aux", "*.bbl", "*.blg", "*.fdb_latexmk", "*.fls", "*.log",
    "*.out", "*.toc"
  ]
}
